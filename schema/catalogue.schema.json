{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/LensCatalogue",
  "definitions": {
    "LensCatalogue": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/CatalogueElement"
      },
      "description": "The top-level catalogue type passed to Lens."
    },
    "CatalogueElement": {
      "type": "object",
      "properties": {
        "type": {
          "enum": [
            "CatalogueGroup",
            "SelectElement",
            "AutocompleteElement",
            "NumericRangeElement",
            "DateRangeElement",
            "FreeTextElement"
          ]
        }
      },
      "required": [
        "type"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "type": "string",
                "const": "CatalogueGroup"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/CatalogueGroup"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "type": "string",
                "const": "SelectElement"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/SelectElement"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "type": "string",
                "const": "AutocompleteElement"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/AutocompleteElement"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "type": "string",
                "const": "NumericRangeElement"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/NumericRangeElement"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "type": "string",
                "const": "DateRangeElement"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/DateRangeElement"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "type": "string",
                "const": "FreeTextElement"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/FreeTextElement"
          }
        }
      ]
    },
    "CatalogueGroup": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "CatalogueGroup"
        },
        "name": {
          "type": "string",
          "description": "The group's user-facing display name."
        },
        "elements": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CatalogueElement"
          },
          "description": "The list of catalogue elements in the group."
        },
        "infoButtonText": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional text accessed by clicking a \"ⓘ\" button."
        },
        "infoLink": {
          "type": "object",
          "properties": {
            "link": {
              "type": "string"
            },
            "display": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name."
        }
      },
      "required": [
        "type",
        "name",
        "elements"
      ],
      "additionalProperties": false,
      "description": "A logical grouping of catalogue elements rendered as a collapsible entry in the catalogue tree."
    },
    "SelectElement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "SelectElement"
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CatalogueOption"
          }
        },
        "key": {
          "type": "string",
          "description": "A key that uniquely identifies the catalogue element."
        },
        "name": {
          "type": "string",
          "description": "The element's user-facing display name."
        },
        "infoButtonText": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional text accessed by clicking a \"ⓘ\" button next to the display name."
        },
        "infoLink": {
          "type": "object",
          "properties": {
            "link": {
              "type": "string"
            },
            "display": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name."
        }
      },
      "required": [
        "key",
        "name",
        "options",
        "type"
      ],
      "description": "A catalogue element that lets the user select one or more options from a predefined list rendered in the catalogue tree."
    },
    "CatalogueOption": {
      "type": "object",
      "properties": {
        "value": {
          "type": "string",
          "description": "The catalogue option's value identifier."
        },
        "name": {
          "type": "string",
          "description": "The catalogue option's user-facing display name."
        },
        "description": {
          "type": "string",
          "description": "Optional description shown during autocompletion."
        },
        "aggregatedValue": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/AggregatedValue"
            }
          },
          "description": "Optional aggregate expansion represented as a nested list: outer array = AND, inner array = OR."
        },
        "suboptions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CatalogueOption"
          },
          "description": "Nested sub-options."
        },
        "selectable": {
          "type": "boolean",
          "description": "Whether this option can be selected by the user. Defaults to true."
        }
      },
      "required": [
        "value",
        "name"
      ],
      "additionalProperties": false
    },
    "AggregatedValue": {
      "type": "object",
      "properties": {
        "key": {
          "type": "string",
          "description": "Catalogue element key referenced by this aggregated value entry."
        },
        "value": {
          "type": "string",
          "description": "Catalogue option value referenced by this aggregated value entry."
        }
      },
      "required": [
        "key",
        "value"
      ],
      "additionalProperties": false
    },
    "AutocompleteElement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "AutocompleteElement"
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CatalogueOption"
          }
        },
        "key": {
          "type": "string",
          "description": "A key that uniquely identifies the catalogue element."
        },
        "name": {
          "type": "string",
          "description": "The element's user-facing display name."
        },
        "infoButtonText": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional text accessed by clicking a \"ⓘ\" button next to the display name."
        },
        "infoLink": {
          "type": "object",
          "properties": {
            "link": {
              "type": "string"
            },
            "display": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name."
        }
      },
      "required": [
        "key",
        "name",
        "options",
        "type"
      ],
      "description": "A catalogue element that lets the user find and select options via an autocomplete text box."
    },
    "NumericRangeElement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "NumericRangeElement"
        },
        "min": {
          "type": "number",
          "description": "The smallest value the user can enter."
        },
        "max": {
          "type": "number",
          "description": "The largest value the user can enter."
        },
        "unitText": {
          "type": "string",
          "description": "Optional unit text shown next to the input field, e.g. \"kg\"."
        },
        "key": {
          "type": "string",
          "description": "A key that uniquely identifies the catalogue element."
        },
        "name": {
          "type": "string",
          "description": "The element's user-facing display name."
        },
        "infoButtonText": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional text accessed by clicking a \"ⓘ\" button next to the display name."
        },
        "infoLink": {
          "type": "object",
          "properties": {
            "link": {
              "type": "string"
            },
            "display": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name."
        }
      },
      "required": [
        "key",
        "name",
        "type"
      ],
      "description": "A catalogue element that lets the user specify a numeric range."
    },
    "DateRangeElement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "DateRangeElement"
        },
        "min": {
          "type": "string",
          "description": "The earliest date the user can pick.",
          "format": "date"
        },
        "max": {
          "type": "string",
          "description": "The latest date the user can pick.",
          "format": "date"
        },
        "key": {
          "type": "string",
          "description": "A key that uniquely identifies the catalogue element."
        },
        "name": {
          "type": "string",
          "description": "The element's user-facing display name."
        },
        "infoButtonText": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional text accessed by clicking a \"ⓘ\" button next to the display name."
        },
        "infoLink": {
          "type": "object",
          "properties": {
            "link": {
              "type": "string"
            },
            "display": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name."
        }
      },
      "required": [
        "key",
        "name",
        "type"
      ],
      "description": "A catalogue element that lets the user specify a date range."
    },
    "FreeTextElement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "FreeTextElement"
        },
        "key": {
          "type": "string",
          "description": "A key that uniquely identifies the catalogue element."
        },
        "name": {
          "type": "string",
          "description": "The element's user-facing display name."
        },
        "infoButtonText": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional text accessed by clicking a \"ⓘ\" button next to the display name."
        },
        "infoLink": {
          "type": "object",
          "properties": {
            "link": {
              "type": "string"
            },
            "display": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name."
        }
      },
      "required": [
        "key",
        "name",
        "type"
      ],
      "description": "A catalogue element that lets the user specify a free-text string."
    }
  }
}
