{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/LensCatalogue",
  "definitions": {
    "LensCatalogue": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/CatalogueElement"
      },
      "description": "The top-level catalogue type passed to Lens."
    },
    "CatalogueElement": {
      "type": "object",
      "properties": {
        "type": {
          "enum": [
            "CatalogueGroup",
            "SelectElement",
            "AutocompleteElement",
            "NumericRangeElement",
            "DateRangeElement",
            "FreeTextElement"
          ]
        }
      },
      "required": [
        "type"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "type": "string",
                "const": "CatalogueGroup"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/CatalogueGroup"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "type": "string",
                "const": "SelectElement"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/SelectElement"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "type": "string",
                "const": "AutocompleteElement"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/AutocompleteElement"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "type": "string",
                "const": "NumericRangeElement"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/NumericRangeElement"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "type": "string",
                "const": "DateRangeElement"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/DateRangeElement"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "type": "string",
                "const": "FreeTextElement"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/FreeTextElement"
          }
        }
      ]
    },
    "CatalogueGroup": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "CatalogueGroup"
        },
        "name": {
          "type": "string",
          "description": "The group's user-facing display name."
        },
        "elements": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CatalogueElement"
          },
          "description": "The list of catalogue elements in the group."
        },
        "infoButtonText": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional text accessed by clicking a \"ⓘ\" button."
        },
        "infoLink": {
          "type": "object",
          "properties": {
            "link": {
              "type": "string"
            },
            "display": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name."
        }
      },
      "required": [
        "type",
        "name",
        "elements"
      ],
      "additionalProperties": false,
      "description": "A logical grouping of catalogue elements rendered as a collapsible entry in the catalogue tree."
    },
    "SelectElement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "SelectElement"
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CatalogueOption"
          }
        },
        "key": {
          "type": "string",
          "description": "A key that uniquely identifies the catalogue element."
        },
        "name": {
          "type": "string",
          "description": "The element's user-facing display name."
        },
        "infoButtonText": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional text accessed by clicking a \"ⓘ\" button next to the display name."
        },
        "infoLink": {
          "type": "object",
          "properties": {
            "link": {
              "type": "string"
            },
            "display": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name."
        },
        "domains": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional list of domain display names this element belongs to. If omitted the element is available in all domains."
        },
        "negatable": {
          "type": "boolean",
          "description": "When true, a danger-coloured minus button is shown next to the element, allowing the user to add a negated (NOT) filter."
        }
      },
      "required": [
        "key",
        "name",
        "options",
        "type"
      ],
      "description": "A catalogue element that lets the user select one or more options from a predefined list rendered in the catalogue tree."
    },
    "CatalogueOption": {
      "type": "object",
      "properties": {
        "value": {
          "type": "string",
          "description": "The catalogue option's value identifier."
        },
        "name": {
          "type": "string",
          "description": "The catalogue option's user-facing display name."
        },
        "description": {
          "type": "string",
          "description": "Optional description shown during autocompletion."
        },
        "ast": {
          "$ref": "#/definitions/AstNode",
          "description": "Optional AST override. When set, selecting this option inserts this AST subtree instead of a simple SetFilter with the value."
        },
        "suboptions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CatalogueOption"
          },
          "description": "Nested sub-options."
        },
        "visible": {
          "type": "boolean",
          "description": "Whether this option is visible in the catalogue tree. Defaults to true."
        }
      },
      "required": [
        "value",
        "name"
      ],
      "additionalProperties": false
    },
    "AstNode": {
      "type": "object",
      "properties": {
        "type": {
          "enum": [
            "AndOperator",
            "OrOperator",
            "NotOperator",
            "SetFilter",
            "NumericRangeFilter",
            "DateRangeFilter"
          ]
        }
      },
      "required": [
        "type"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "type": "string",
                "const": "AndOperator"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/AndOperator"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "type": "string",
                "const": "OrOperator"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/OrOperator"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "type": "string",
                "const": "NotOperator"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/NotOperator"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "type": "string",
                "const": "SetFilter"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/SetFilter"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "type": "string",
                "const": "NumericRangeFilter"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/NumericRangeFilter"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "type": "string",
                "const": "DateRangeFilter"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/DateRangeFilter"
          }
        }
      ]
    },
    "AndOperator": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "AndOperator"
        },
        "operands": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/AstNode"
          }
        }
      },
      "required": [
        "type",
        "operands"
      ],
      "additionalProperties": false
    },
    "OrOperator": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "OrOperator"
        },
        "operands": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/AstNode"
          }
        }
      },
      "required": [
        "type",
        "operands"
      ],
      "additionalProperties": false
    },
    "NotOperator": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "NotOperator"
        },
        "operand": {
          "$ref": "#/definitions/AstNode"
        }
      },
      "required": [
        "type",
        "operand"
      ],
      "additionalProperties": false
    },
    "SetFilter": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "SetFilter"
        },
        "key": {
          "type": "string"
        },
        "values": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "type",
        "key",
        "values"
      ],
      "additionalProperties": false,
      "description": "Filter that checks set membership. Equality is a special case with a single entry in the `values` array."
    },
    "NumericRangeFilter": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "NumericRangeFilter"
        },
        "key": {
          "type": "string"
        },
        "min": {
          "type": "number",
          "description": "Ranges are inclusive. At least one bound must be specified."
        },
        "max": {
          "type": "number"
        }
      },
      "required": [
        "type",
        "key"
      ],
      "additionalProperties": false
    },
    "DateRangeFilter": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "DateRangeFilter"
        },
        "key": {
          "type": "string"
        },
        "min": {
          "type": "string",
          "description": "Ranges are inclusive. At least one bound must be specified. Bounds are in the format YYYY-MM-DD.",
          "format": "date"
        },
        "max": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "key"
      ],
      "additionalProperties": false
    },
    "AutocompleteElement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "AutocompleteElement"
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CatalogueOption"
          }
        },
        "key": {
          "type": "string",
          "description": "A key that uniquely identifies the catalogue element."
        },
        "name": {
          "type": "string",
          "description": "The element's user-facing display name."
        },
        "infoButtonText": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional text accessed by clicking a \"ⓘ\" button next to the display name."
        },
        "infoLink": {
          "type": "object",
          "properties": {
            "link": {
              "type": "string"
            },
            "display": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name."
        },
        "domains": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional list of domain display names this element belongs to. If omitted the element is available in all domains."
        },
        "negatable": {
          "type": "boolean",
          "description": "When true, a danger-coloured minus button is shown next to the element, allowing the user to add a negated (NOT) filter."
        }
      },
      "required": [
        "key",
        "name",
        "options",
        "type"
      ],
      "description": "A catalogue element that lets the user find and select options via an autocomplete text box."
    },
    "NumericRangeElement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "NumericRangeElement"
        },
        "min": {
          "type": "number",
          "description": "The smallest value the user can enter."
        },
        "max": {
          "type": "number",
          "description": "The largest value the user can enter."
        },
        "unitText": {
          "type": "string",
          "description": "Optional unit text shown next to the input field, e.g. \"kg\"."
        },
        "key": {
          "type": "string",
          "description": "A key that uniquely identifies the catalogue element."
        },
        "name": {
          "type": "string",
          "description": "The element's user-facing display name."
        },
        "infoButtonText": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional text accessed by clicking a \"ⓘ\" button next to the display name."
        },
        "infoLink": {
          "type": "object",
          "properties": {
            "link": {
              "type": "string"
            },
            "display": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name."
        },
        "domains": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional list of domain display names this element belongs to. If omitted the element is available in all domains."
        },
        "negatable": {
          "type": "boolean",
          "description": "When true, a danger-coloured minus button is shown next to the element, allowing the user to add a negated (NOT) filter."
        }
      },
      "required": [
        "key",
        "name",
        "type"
      ],
      "description": "A catalogue element that lets the user specify a numeric range."
    },
    "DateRangeElement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "DateRangeElement"
        },
        "min": {
          "type": "string",
          "description": "The earliest date the user can pick.",
          "format": "date"
        },
        "max": {
          "type": "string",
          "description": "The latest date the user can pick.",
          "format": "date"
        },
        "key": {
          "type": "string",
          "description": "A key that uniquely identifies the catalogue element."
        },
        "name": {
          "type": "string",
          "description": "The element's user-facing display name."
        },
        "infoButtonText": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional text accessed by clicking a \"ⓘ\" button next to the display name."
        },
        "infoLink": {
          "type": "object",
          "properties": {
            "link": {
              "type": "string"
            },
            "display": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name."
        },
        "domains": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional list of domain display names this element belongs to. If omitted the element is available in all domains."
        },
        "negatable": {
          "type": "boolean",
          "description": "When true, a danger-coloured minus button is shown next to the element, allowing the user to add a negated (NOT) filter."
        }
      },
      "required": [
        "key",
        "name",
        "type"
      ],
      "description": "A catalogue element that lets the user specify a date range."
    },
    "FreeTextElement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "FreeTextElement"
        },
        "key": {
          "type": "string",
          "description": "A key that uniquely identifies the catalogue element."
        },
        "name": {
          "type": "string",
          "description": "The element's user-facing display name."
        },
        "infoButtonText": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional text accessed by clicking a \"ⓘ\" button next to the display name."
        },
        "infoLink": {
          "type": "object",
          "properties": {
            "link": {
              "type": "string"
            },
            "display": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name."
        },
        "domains": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional list of domain display names this element belongs to. If omitted the element is available in all domains."
        },
        "negatable": {
          "type": "boolean",
          "description": "When true, a danger-coloured minus button is shown next to the element, allowing the user to add a negated (NOT) filter."
        }
      },
      "required": [
        "key",
        "name",
        "type"
      ],
      "description": "A catalogue element that lets the user specify a free-text string."
    }
  }
}
