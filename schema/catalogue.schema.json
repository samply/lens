{
  "$ref": "#/definitions/LensCatalogue",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "AggregatedValue": {
      "additionalProperties": false,
      "properties": {
        "key": {
          "description": "Catalogue element key referenced by this aggregated value entry.",
          "type": "string"
        },
        "value": {
          "description": "Catalogue option value referenced by this aggregated value entry.",
          "type": "string"
        }
      },
      "required": [
        "key",
        "value"
      ],
      "type": "object"
    },
    "AutocompleteElement": {
      "additionalProperties": false,
      "description": "A catalogue element that lets the user find and select options via an autocomplete text box.",
      "properties": {
        "infoButtonText": {
          "description": "Optional text accessed by clicking a \"ⓘ\" button next to the display name.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "infoLink": {
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name.",
          "properties": {
            "display": {
              "type": "string"
            },
            "link": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "type": "object"
        },
        "key": {
          "description": "A key that uniquely identifies the catalogue element.",
          "type": "string"
        },
        "name": {
          "description": "The element's user-facing display name.",
          "type": "string"
        },
        "options": {
          "items": {
            "$ref": "#/definitions/CatalogueOption"
          },
          "type": "array"
        },
        "type": {
          "const": "AutocompleteElement",
          "type": "string"
        }
      },
      "required": [
        "key",
        "name",
        "options",
        "type"
      ],
      "type": "object"
    },
    "CatalogueElement": {
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "CatalogueGroup",
                "type": "string"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/CatalogueGroup"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "SelectElement",
                "type": "string"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/SelectElement"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "AutocompleteElement",
                "type": "string"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/AutocompleteElement"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "NumericRangeElement",
                "type": "string"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/NumericRangeElement"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "DateRangeElement",
                "type": "string"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/DateRangeElement"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "FreeTextElement",
                "type": "string"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/FreeTextElement"
          }
        }
      ],
      "properties": {
        "type": {
          "enum": [
            "CatalogueGroup",
            "SelectElement",
            "AutocompleteElement",
            "NumericRangeElement",
            "DateRangeElement",
            "FreeTextElement"
          ]
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "CatalogueGroup": {
      "additionalProperties": false,
      "description": "A logical grouping of catalogue elements rendered as a collapsible entry in the catalogue tree.",
      "properties": {
        "elements": {
          "description": "The list of catalogue elements in the group.",
          "items": {
            "$ref": "#/definitions/CatalogueElement"
          },
          "type": "array"
        },
        "infoButtonText": {
          "description": "Optional text accessed by clicking a \"ⓘ\" button.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "infoLink": {
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name.",
          "properties": {
            "display": {
              "type": "string"
            },
            "link": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "type": "object"
        },
        "name": {
          "description": "The group's user-facing display name.",
          "type": "string"
        },
        "type": {
          "const": "CatalogueGroup",
          "type": "string"
        }
      },
      "required": [
        "type",
        "name",
        "elements"
      ],
      "type": "object"
    },
    "CatalogueOption": {
      "additionalProperties": false,
      "properties": {
        "aggregatedValue": {
          "description": "Optional aggregate expansion represented as a nested list: outer array = AND, inner array = OR.",
          "items": {
            "items": {
              "$ref": "#/definitions/AggregatedValue"
            },
            "type": "array"
          },
          "type": "array"
        },
        "description": {
          "description": "Optional description shown during autocompletion.",
          "type": "string"
        },
        "name": {
          "description": "The catalogue option's user-facing display name.",
          "type": "string"
        },
        "selectable": {
          "description": "Whether this option can be selected by the user. Defaults to true.",
          "type": "boolean"
        },
        "suboptions": {
          "description": "Nested sub-options.",
          "items": {
            "$ref": "#/definitions/CatalogueOption"
          },
          "type": "array"
        },
        "value": {
          "description": "The catalogue option's value identifier.",
          "type": "string"
        }
      },
      "required": [
        "value",
        "name"
      ],
      "type": "object"
    },
    "DateRangeElement": {
      "additionalProperties": false,
      "description": "A catalogue element that lets the user specify a date range.",
      "properties": {
        "infoButtonText": {
          "description": "Optional text accessed by clicking a \"ⓘ\" button next to the display name.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "infoLink": {
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name.",
          "properties": {
            "display": {
              "type": "string"
            },
            "link": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "type": "object"
        },
        "key": {
          "description": "A key that uniquely identifies the catalogue element.",
          "type": "string"
        },
        "max": {
          "description": "The latest date the user can pick.",
          "format": "date",
          "type": "string"
        },
        "min": {
          "description": "The earliest date the user can pick.",
          "format": "date",
          "type": "string"
        },
        "name": {
          "description": "The element's user-facing display name.",
          "type": "string"
        },
        "type": {
          "const": "DateRangeElement",
          "type": "string"
        }
      },
      "required": [
        "key",
        "name",
        "type"
      ],
      "type": "object"
    },
    "FreeTextElement": {
      "additionalProperties": false,
      "description": "A catalogue element that lets the user specify a free-text string.",
      "properties": {
        "infoButtonText": {
          "description": "Optional text accessed by clicking a \"ⓘ\" button next to the display name.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "infoLink": {
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name.",
          "properties": {
            "display": {
              "type": "string"
            },
            "link": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "type": "object"
        },
        "key": {
          "description": "A key that uniquely identifies the catalogue element.",
          "type": "string"
        },
        "name": {
          "description": "The element's user-facing display name.",
          "type": "string"
        },
        "type": {
          "const": "FreeTextElement",
          "type": "string"
        }
      },
      "required": [
        "key",
        "name",
        "type"
      ],
      "type": "object"
    },
    "LensCatalogue": {
      "description": "The top-level catalogue type passed to Lens.",
      "items": {
        "$ref": "#/definitions/CatalogueElement"
      },
      "type": "array"
    },
    "NumericRangeElement": {
      "additionalProperties": false,
      "description": "A catalogue element that lets the user specify a numeric range.",
      "properties": {
        "infoButtonText": {
          "description": "Optional text accessed by clicking a \"ⓘ\" button next to the display name.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "infoLink": {
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name.",
          "properties": {
            "display": {
              "type": "string"
            },
            "link": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "type": "object"
        },
        "key": {
          "description": "A key that uniquely identifies the catalogue element.",
          "type": "string"
        },
        "max": {
          "description": "The largest value the user can enter.",
          "type": "number"
        },
        "min": {
          "description": "The smallest value the user can enter.",
          "type": "number"
        },
        "name": {
          "description": "The element's user-facing display name.",
          "type": "string"
        },
        "type": {
          "const": "NumericRangeElement",
          "type": "string"
        },
        "unitText": {
          "description": "Optional unit text shown next to the input field, e.g. \"kg\".",
          "type": "string"
        }
      },
      "required": [
        "key",
        "name",
        "type"
      ],
      "type": "object"
    },
    "SelectElement": {
      "additionalProperties": false,
      "description": "A catalogue element that lets the user select one or more options from a predefined list rendered in the catalogue tree.",
      "properties": {
        "infoButtonText": {
          "description": "Optional text accessed by clicking a \"ⓘ\" button next to the display name.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "infoLink": {
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name.",
          "properties": {
            "display": {
              "type": "string"
            },
            "link": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "type": "object"
        },
        "key": {
          "description": "A key that uniquely identifies the catalogue element.",
          "type": "string"
        },
        "name": {
          "description": "The element's user-facing display name.",
          "type": "string"
        },
        "options": {
          "items": {
            "$ref": "#/definitions/CatalogueOption"
          },
          "type": "array"
        },
        "type": {
          "const": "SelectElement",
          "type": "string"
        }
      },
      "required": [
        "key",
        "name",
        "options",
        "type"
      ],
      "type": "object"
    }
  }
}

