{
  "$ref": "#/definitions/LensCatalogue",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "AndOperator": {
      "additionalProperties": false,
      "properties": {
        "operands": {
          "items": {
            "$ref": "#/definitions/AstNode"
          },
          "type": "array"
        },
        "type": {
          "const": "AndOperator",
          "type": "string"
        }
      },
      "required": [
        "type",
        "operands"
      ],
      "type": "object"
    },
    "AstNode": {
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "AndOperator",
                "type": "string"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/AndOperator"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "OrOperator",
                "type": "string"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/OrOperator"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "NotOperator",
                "type": "string"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/NotOperator"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "SetFilter",
                "type": "string"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/SetFilter"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "NumericRangeFilter",
                "type": "string"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/NumericRangeFilter"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "DateRangeFilter",
                "type": "string"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/DateRangeFilter"
          }
        }
      ],
      "properties": {
        "type": {
          "enum": [
            "AndOperator",
            "OrOperator",
            "NotOperator",
            "SetFilter",
            "NumericRangeFilter",
            "DateRangeFilter"
          ]
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "AutocompleteElement": {
      "additionalProperties": false,
      "description": "A catalogue element that lets the user find and select options via an autocomplete text box.",
      "properties": {
        "domains": {
          "description": "Optional list of domain keys this element belongs to. If omitted the element is available in all domains.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "infoButtonText": {
          "description": "Optional text accessed by clicking a \"ⓘ\" button next to the display name.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "infoLink": {
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name.",
          "properties": {
            "display": {
              "type": "string"
            },
            "link": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "type": "object"
        },
        "key": {
          "description": "A key that uniquely identifies the catalogue element.",
          "type": "string"
        },
        "name": {
          "description": "The element's user-facing display name.",
          "type": "string"
        },
        "negatable": {
          "description": "When true, a danger-coloured minus button is shown next to the element, allowing the user to add a negated (NOT) filter.",
          "type": "boolean"
        },
        "options": {
          "items": {
            "$ref": "#/definitions/CatalogueOption"
          },
          "type": "array"
        },
        "type": {
          "const": "AutocompleteElement",
          "type": "string"
        }
      },
      "required": [
        "key",
        "name",
        "options",
        "type"
      ],
      "type": "object"
    },
    "CatalogueElement": {
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "CatalogueGroup",
                "type": "string"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/CatalogueGroup"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "SelectElement",
                "type": "string"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/SelectElement"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "AutocompleteElement",
                "type": "string"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/AutocompleteElement"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "NumericRangeElement",
                "type": "string"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/NumericRangeElement"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "DateRangeElement",
                "type": "string"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/DateRangeElement"
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "FreeTextElement",
                "type": "string"
              }
            }
          },
          "then": {
            "$ref": "#/definitions/FreeTextElement"
          }
        }
      ],
      "properties": {
        "type": {
          "enum": [
            "CatalogueGroup",
            "SelectElement",
            "AutocompleteElement",
            "NumericRangeElement",
            "DateRangeElement",
            "FreeTextElement"
          ]
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "CatalogueGroup": {
      "additionalProperties": false,
      "description": "A logical grouping of catalogue elements rendered as a collapsible entry in the catalogue tree.",
      "properties": {
        "elements": {
          "description": "The list of catalogue elements in the group.",
          "items": {
            "$ref": "#/definitions/CatalogueElement"
          },
          "type": "array"
        },
        "infoButtonText": {
          "description": "Optional text accessed by clicking a \"ⓘ\" button.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "infoLink": {
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name.",
          "properties": {
            "display": {
              "type": "string"
            },
            "link": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "type": "object"
        },
        "name": {
          "description": "The group's user-facing display name.",
          "type": "string"
        },
        "type": {
          "const": "CatalogueGroup",
          "type": "string"
        }
      },
      "required": [
        "type",
        "name",
        "elements"
      ],
      "type": "object"
    },
    "CatalogueOption": {
      "additionalProperties": false,
      "properties": {
        "ast": {
          "$ref": "#/definitions/AstNode",
          "description": "Optional AST override. When set, selecting this option inserts this AST subtree instead of a simple SetFilter with the value."
        },
        "description": {
          "description": "Optional description shown during autocompletion.",
          "type": "string"
        },
        "name": {
          "description": "The catalogue option's user-facing display name.",
          "type": "string"
        },
        "suboptions": {
          "description": "Nested sub-options.",
          "items": {
            "$ref": "#/definitions/CatalogueOption"
          },
          "type": "array"
        },
        "value": {
          "description": "The catalogue option's value identifier.",
          "type": "string"
        },
        "visible": {
          "description": "Whether this option is visible in the catalogue tree. Defaults to true.",
          "type": "boolean"
        }
      },
      "required": [
        "value",
        "name"
      ],
      "type": "object"
    },
    "DateRangeElement": {
      "additionalProperties": false,
      "description": "A catalogue element that lets the user specify a date range.",
      "properties": {
        "domains": {
          "description": "Optional list of domain keys this element belongs to. If omitted the element is available in all domains.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "infoButtonText": {
          "description": "Optional text accessed by clicking a \"ⓘ\" button next to the display name.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "infoLink": {
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name.",
          "properties": {
            "display": {
              "type": "string"
            },
            "link": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "type": "object"
        },
        "key": {
          "description": "A key that uniquely identifies the catalogue element.",
          "type": "string"
        },
        "max": {
          "description": "The latest date the user can pick.",
          "format": "date",
          "type": "string"
        },
        "min": {
          "description": "The earliest date the user can pick.",
          "format": "date",
          "type": "string"
        },
        "name": {
          "description": "The element's user-facing display name.",
          "type": "string"
        },
        "negatable": {
          "description": "When true, a danger-coloured minus button is shown next to the element, allowing the user to add a negated (NOT) filter.",
          "type": "boolean"
        },
        "type": {
          "const": "DateRangeElement",
          "type": "string"
        }
      },
      "required": [
        "key",
        "name",
        "type"
      ],
      "type": "object"
    },
    "DateRangeFilter": {
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string"
        },
        "max": {
          "type": "string"
        },
        "min": {
          "description": "Ranges are inclusive. At least one bound must be specified. Bounds are in the format YYYY-MM-DD.",
          "format": "date",
          "type": "string"
        },
        "type": {
          "const": "DateRangeFilter",
          "type": "string"
        }
      },
      "required": [
        "type",
        "key"
      ],
      "type": "object"
    },
    "FreeTextElement": {
      "additionalProperties": false,
      "description": "A catalogue element that lets the user specify a free-text string.",
      "properties": {
        "domains": {
          "description": "Optional list of domain keys this element belongs to. If omitted the element is available in all domains.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "infoButtonText": {
          "description": "Optional text accessed by clicking a \"ⓘ\" button next to the display name.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "infoLink": {
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name.",
          "properties": {
            "display": {
              "type": "string"
            },
            "link": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "type": "object"
        },
        "key": {
          "description": "A key that uniquely identifies the catalogue element.",
          "type": "string"
        },
        "name": {
          "description": "The element's user-facing display name.",
          "type": "string"
        },
        "negatable": {
          "description": "When true, a danger-coloured minus button is shown next to the element, allowing the user to add a negated (NOT) filter.",
          "type": "boolean"
        },
        "type": {
          "const": "FreeTextElement",
          "type": "string"
        }
      },
      "required": [
        "key",
        "name",
        "type"
      ],
      "type": "object"
    },
    "LensCatalogue": {
      "description": "The top-level catalogue type passed to Lens.",
      "items": {
        "$ref": "#/definitions/CatalogueElement"
      },
      "type": "array"
    },
    "NotOperator": {
      "additionalProperties": false,
      "properties": {
        "operand": {
          "$ref": "#/definitions/AstNode"
        },
        "type": {
          "const": "NotOperator",
          "type": "string"
        }
      },
      "required": [
        "type",
        "operand"
      ],
      "type": "object"
    },
    "NumericRangeElement": {
      "additionalProperties": false,
      "description": "A catalogue element that lets the user specify a numeric range.",
      "properties": {
        "domains": {
          "description": "Optional list of domain keys this element belongs to. If omitted the element is available in all domains.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "infoButtonText": {
          "description": "Optional text accessed by clicking a \"ⓘ\" button next to the display name.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "infoLink": {
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name.",
          "properties": {
            "display": {
              "type": "string"
            },
            "link": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "type": "object"
        },
        "key": {
          "description": "A key that uniquely identifies the catalogue element.",
          "type": "string"
        },
        "max": {
          "description": "The largest value the user can enter.",
          "type": "number"
        },
        "min": {
          "description": "The smallest value the user can enter.",
          "type": "number"
        },
        "name": {
          "description": "The element's user-facing display name.",
          "type": "string"
        },
        "negatable": {
          "description": "When true, a danger-coloured minus button is shown next to the element, allowing the user to add a negated (NOT) filter.",
          "type": "boolean"
        },
        "type": {
          "const": "NumericRangeElement",
          "type": "string"
        },
        "unitText": {
          "description": "Optional unit text shown next to the input field, e.g. \"kg\".",
          "type": "string"
        }
      },
      "required": [
        "key",
        "name",
        "type"
      ],
      "type": "object"
    },
    "NumericRangeFilter": {
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string"
        },
        "max": {
          "type": "number"
        },
        "min": {
          "description": "Ranges are inclusive. At least one bound must be specified.",
          "type": "number"
        },
        "type": {
          "const": "NumericRangeFilter",
          "type": "string"
        }
      },
      "required": [
        "type",
        "key"
      ],
      "type": "object"
    },
    "OrOperator": {
      "additionalProperties": false,
      "properties": {
        "operands": {
          "items": {
            "$ref": "#/definitions/AstNode"
          },
          "type": "array"
        },
        "type": {
          "const": "OrOperator",
          "type": "string"
        }
      },
      "required": [
        "type",
        "operands"
      ],
      "type": "object"
    },
    "SelectElement": {
      "additionalProperties": false,
      "description": "A catalogue element that lets the user select one or more options from a predefined list rendered in the catalogue tree.",
      "properties": {
        "domains": {
          "description": "Optional list of domain keys this element belongs to. If omitted the element is available in all domains.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "infoButtonText": {
          "description": "Optional text accessed by clicking a \"ⓘ\" button next to the display name.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "infoLink": {
          "additionalProperties": false,
          "description": "Optional hyperlink shown next to the display name.",
          "properties": {
            "display": {
              "type": "string"
            },
            "link": {
              "type": "string"
            }
          },
          "required": [
            "link",
            "display"
          ],
          "type": "object"
        },
        "key": {
          "description": "A key that uniquely identifies the catalogue element.",
          "type": "string"
        },
        "name": {
          "description": "The element's user-facing display name.",
          "type": "string"
        },
        "negatable": {
          "description": "When true, a danger-coloured minus button is shown next to the element, allowing the user to add a negated (NOT) filter.",
          "type": "boolean"
        },
        "options": {
          "items": {
            "$ref": "#/definitions/CatalogueOption"
          },
          "type": "array"
        },
        "type": {
          "const": "SelectElement",
          "type": "string"
        }
      },
      "required": [
        "key",
        "name",
        "options",
        "type"
      ],
      "type": "object"
    },
    "SetFilter": {
      "additionalProperties": false,
      "description": "Filter that checks set membership. Equality is a special case with a single entry in the `values` array.",
      "properties": {
        "key": {
          "type": "string"
        },
        "type": {
          "const": "SetFilter",
          "type": "string"
        },
        "values": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "type",
        "key",
        "values"
      ],
      "type": "object"
    }
  }
}

