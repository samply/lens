{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/LensOptions",
  "definitions": {
    "LensOptions": {
      "type": "object",
      "properties": {
        "spotUrl": {
          "type": "string",
          "description": "URL of the Spot API endpoint used by `querySpot` function and facet counts."
        },
        "sitesToQuery": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of sites to query used by `querySpot` function and facet counts. If not set no sites are sent to Spot and Spot determines the sites to query."
        },
        "chartOptions": {
          "$ref": "#/definitions/ChartOptions"
        },
        "siteMappings": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "$ref": "#/definitions/SiteInfo"
              }
            ]
          },
          "description": "Maps site ID to site info or string (display name only) for backwards compatibility."
        },
        "collectionBaseUrl": {
          "type": "string",
          "description": "Base URL of the collections in the BBMRI-ERIC Directory. If set, collection IDs in the \"siteMappings\" are appended to this base URL to create the full URL of the collection in the BBMRI-ERIC Directory."
        },
        "negotiateOptions": {
          "$ref": "#/definitions/NegotiateOptions"
        },
        "tableOptions": {
          "$ref": "#/definitions/TableOptions"
        },
        "resultSummaryOptions": {
          "$ref": "#/definitions/ResultSummaryOptions"
        },
        "language": {
          "type": "string",
          "description": "Two letter language code of the application language"
        },
        "texts": {
          "$ref": "#/definitions/Texts",
          "description": "Allows to customize texts and add new translations"
        },
        "facetCount": {
          "$ref": "#/definitions/FacetCountOptions",
          "description": "If set, fetch and display facet counts (number of results per discrete value) in the catalogue."
        },
        "autoUpdateQueryInUrl": {
          "type": "boolean",
          "description": "Whether to automatically update the query in the URL when it changes (default: true)"
        },
        "autoUpdateDatarequestsInUrl": {
          "type": "boolean",
          "description": "Whether to automatically update datarequests in the URL when they change (default: true)"
        }
      },
      "additionalProperties": {}
    },
    "ChartOptions": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/ChartOption"
      }
    },
    "ChartOption": {
      "type": "object",
      "properties": {
        "legendMapping": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "hintText": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "aggregations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tooltips": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "accumulatedValues": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "values": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "name",
              "values"
            ],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "SiteInfo": {
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "Display name in the results table"
        },
        "collectionId": {
          "type": "string",
          "description": "Collection ID in the BBMRI-ERIC Directory"
        }
      },
      "required": [
        "displayName"
      ],
      "additionalProperties": false
    },
    "NegotiateOptions": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "description": "The URL of the BBMRI Negotiator API endpoint that creates a request to apply for access. The URL path is typically /api/v3/requests. Lens will send a POST request to the URL to start the application process."
        },
        "authorizationHeader": {
          "type": "string",
          "description": "The value of the Authorization header for the POST request."
        }
      },
      "required": [
        "url",
        "authorizationHeader"
      ],
      "additionalProperties": false
    },
    "TableOptions": {
      "type": "object",
      "properties": {
        "headerData": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/HeaderData"
          }
        }
      },
      "required": [
        "headerData"
      ],
      "additionalProperties": false
    },
    "HeaderData": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "dataKey": {
          "type": "string"
        },
        "aggregatedDataKeys": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "groupCode": {
                "type": "string"
              },
              "stratifierCode": {
                "type": "string"
              },
              "stratumCode": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "hintText": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "title"
      ],
      "additionalProperties": false
    },
    "ResultSummaryOptions": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "infoButtonText": {
          "type": "string"
        },
        "dataTypes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/HeaderData"
          }
        }
      },
      "required": [
        "dataTypes"
      ],
      "additionalProperties": false
    },
    "Texts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        }
      },
      "description": "A map of texts that are displayed in the application. The keys are used to look up the text in the application code. The values are objects that map two letter language codes to the actual text."
    },
    "FacetCountOptions": {
      "type": "object",
      "properties": {
        "hoverText": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Hover text for each stratifier in the catalogue"
        }
      },
      "required": [
        "hoverText"
      ],
      "additionalProperties": false
    }
  }
}
