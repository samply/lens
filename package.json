{
    "name": "@samply/lens",
    "description": "A web component library for clinical data search and visualisation",
    "version": "0.6.8",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/samply/lens.git"
    },
    "//": "Settings recommended by Vite but without CommonJS exports, see https://vite.dev/guide/build#library-mode",
    "type": "module",
    "files": [
        "dist",
        "schema"
    ],
    "module": "dist/lens.js",
    "types": "dist/lens.d.ts",
    "exports": {
        ".": "./dist/lens.js",
        "./style.css": "./dist/lens.css"
    },
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "build:demo": " vite build --config vite.config.demo.js",
        "preview:demo": "vite preview --config vite.config.demo.js",
        "check": "svelte-check",
        "prepublishOnly": "vite build",
        "version": "npm version -m \"chore: release %s\"",
        "schemagen": "bash scripts/generate-json-schema.bash",
        "book": "mdbook serve book --open",
        "typedoc": "typedoc src/index.ts --watch",
        "test": "vitest"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@sveltejs/vite-plugin-svelte": "^7.2.0",
        "@types/node": "^26.1.1",
        "@types/uuid": "^11.0.0",
        "ajv-cli": "^5.0.0",
        "eslint": "^10.7.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.22.0",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "lint-staged": "^17.1.0",
        "prettier": "^3.9.6",
        "prettier-plugin-svelte": "^4.1.1",
        "rollup": "^4.62.2",
        "svelte": "^5.56.7",
        "svelte-check": "^4.7.3",
        "ts-json-schema-generator": "^2.9.0",
        "typedoc": "^0.28.20",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.65.0",
        "vite": "^8.1.5",
        "vite-plugin-dts": "^5.0.3",
        "vitest": "^4.1.10"
    },
    "dependencies": {
        "@tailwindcss/vite": "^4.3.3",
        "ajv": "^8.20.0",
        "ajv-formats": "^3.0.1",
        "chart.js": "^4.5.1",
        "lucide-svelte": "^1.0.1",
        "tailwindcss": "^4.3.3",
        "uuid": "^14.0.1"
    },
    "lint-staged": {
        "*": [
            "eslint --fix",
            "prettier --ignore-unknown --write"
        ]
    }
}
