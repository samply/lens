{
    "name": "@samply/lens",
    "description": "A Svelte library for clinical data search and visualisation",
    "version": "0.6.4",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/samply/lens.git"
    },
    "type": "module",
    "files": [
        "dist"
    ],
    "svelte": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "svelte": "./dist/index.js"
        }
    },
    "scripts": {
        "dev": "vite dev",
        "build": "svelte-package",
        "build:watch": "svelte-package --watch",
        "build:demo": "vite build",
        "check": "svelte-check",
        "prepublishOnly": "npm run build",
        "version": "npm version -m \"chore: release %s\"",
        "schemagen": "bash scripts/generate-json-schema.bash",
        "book": "mdbook serve book --open",
        "typedoc": "typedoc src/lib/index.ts --watch",
        "test": "vitest"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@sveltejs/adapter-static": "^3.0.10",
        "@sveltejs/kit": "^2.50.1",
        "@sveltejs/package": "^2.5.7",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "@types/node": "^25.1.0",
        "@types/uuid": "^11.0.0",
        "ajv-cli": "^5.0.0",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.14.0",
        "globals": "^17.2.0",
        "jsdom": "^27.4.0",
        "prettier": "^3.8.1",
        "prettier-plugin-svelte": "^3.4.1",
        "rollup": "^4.57.1",
        "svelte": "^5.49.1",
        "svelte-check": "^4.3.5",
        "ts-json-schema-generator": "^2.4.0",
        "typedoc": "^0.28.16",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.54.0",
        "vite": "^7.3.1",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.0.18"
    },
    "dependencies": {
        "ajv": "^8.17.1",
        "ajv-formats": "^3.0.1",
        "chart.js": "^4.5.1",
        "uuid": "^13.0.0"
    },
    "peerDependencies": {
        "svelte": "^5.0.0"
    },
    "sideEffects": [
        "**/*.css"
    ]
}
